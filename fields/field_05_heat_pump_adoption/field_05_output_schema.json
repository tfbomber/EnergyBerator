{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FIELD_05 Heat Pump Adoption Output Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "field_id",
      "segment_id",
      "estimated_heat_pump_adoption",
      "estimated_band",
      "confidence",
      "drivers"
    ],
    "properties": {
      "field_id": { "type": "string", "const": "FIELD_05" },
      "segment_id": { "type": "string" },
      "estimated_heat_pump_adoption": { 
        "type": "number",
        "minimum": 0.0,
        "maximum": 0.35
      },
      "estimated_band": {
        "type": "string",
        "enum": ["VERY_LOW", "LOW", "MEDIUM", "HIGH", "VERY_HIGH"]
      },
      "confidence": {
        "type": "string",
        "enum": ["LOW_MEDIUM", "MEDIUM", "HIGH"]
      },
      "drivers": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }
}
